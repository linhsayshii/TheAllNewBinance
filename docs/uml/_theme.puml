' Shared PlantUML theme for TheAllNewBinance diagrams
skinparam shadowing false
skinparam linetype polyline
skinparam packageStyle rectangle
skinparam componentStyle rectangle
skinparam classAttributeIconSize 0
skinparam BackgroundColor #FCFCFA
skinparam ArrowColor #58616A
skinparam ArrowFontColor #32424C
skinparam ArrowFontSize 11
skinparam DefaultFontName Segoe UI
skinparam DefaultFontSize 13
skinparam TitleFontSize 20
skinparam TitleFontStyle bold
skinparam PackageFontStyle bold
skinparam PackageBorderColor #9AA7B0
skinparam PackageBackgroundColor #F3F6F8
skinparam NoteBackgroundColor #FFF7DD
skinparam NoteBorderColor #D8C48B
skinparam LegendBackgroundColor #F7FAFC
skinparam LegendBorderColor #C9D2D8
skinparam RoundCorner 12
skinparam Padding 10
skinparam nodesep 70
skinparam ranksep 90

skinparam class {
  BackgroundColor #FFFFFF
  BorderColor #6E7B85
  ArrowColor #58616A
  HeaderBackgroundColor #E7EEF3
  FontColor #23313A
}

skinparam component {
  BackgroundColor #FFFFFF
  BorderColor #6E7B85
  FontColor #23313A
}

skinparam interface {
  BackgroundColor #F7FBFF
  BorderColor #54718B
  FontColor #23313A
}

skinparam enum {
  BackgroundColor #FFFDF4
  BorderColor #8A7C4A
  FontColor #3A3220
}

skinparam database {
  BackgroundColor #FFFDF4
  BorderColor #8A7C4A
  FontColor #3A3220
}

skinparam sequence {
  ArrowColor #58616A
  ArrowFontSize 11
  LifeLineBorderColor #7E8A93
  LifeLineBackgroundColor #F5F8FA
  ParticipantBorderColor #6E7B85
  ParticipantBackgroundColor #FFFFFF
  ParticipantFontColor #23313A
  ActorBorderColor #6E7B85
  ActorBackgroundColor #FFFFFF
  GroupBorderColor #9AA7B0
  GroupBackgroundColor #F7FAFC
}
