@startuml TheAllNewBinance_Client
title TheAllNewBinance - Client Class Diagram
!include _theme.puml

top to bottom direction

legend left
  Flow is arranged top-down:
  app/config -> scene -> page/viewmodel -> service/mapper/dto.
endlegend

package "app" {
  class ClientApp {
    - hotReloadService : HotReloadService
    + start(primaryStage : Stage)
    + stop()
    + main(args : String[])
  }
}

package "config" {
  class AppConfig {
    + stylesheets() : List<String>
    + defaultWidth() : double
    + defaultHeight() : double
    + minWidth() : double
    + minHeight() : double
    + isHotReloadEnabled() : boolean
    + sourceResourceRoot() : Optional<Path>
  }

  enum SceneRegistry {
    GENERAL_PAGE
    LOGIN_PAGE
    REGISTER_PAGE
    PRODUCT_DETAIL_PAGE
    PROFILE_PAGE
    --
    + fxmlPath() : String
    + title() : String
  }
}

package "scene" {
  class SceneService {
    - stage : Stage
    - resourceLoader : ResourceLoader
    - stylesheets : List<String>
    - currentSceneRegistry : SceneRegistry
    - activeScenes : List<Scene>
    + switchTo(sceneRegistry : SceneRegistry)
    + currentSceneRegistry() : SceneRegistry
    + currentScene() : Scene
    + activeScenes() : List<Scene>
    + reloadStylesheets()
    + reloadCurrentScene()
  }

  class NavigationService {
    - sceneService : SceneService
    + navigateTo(sceneRegistry : SceneRegistry)
  }
}

package "page.general" {
  class GeneralPageController {
    - cardsContainer : VBox
    - viewModel : GeneralPageViewModel
    + initialize()
  }

  class GeneralPageViewModel {
    - auctionQueryService : AuctionQueryService
    + loadFeaturedAuctions() : List<ProductCardUiModel>
  }
}

package "page" {
  class LoginPageController
  class LoginPageViewModel
  class ProductDetailPageController
  class ProductDetailPageViewModel
  class ProfilePageController
  class ProfilePageViewModel
  class RegisterPageController
  class RegisterPageViewModel
}

package "component" {
  class SearchBarComponentController
  class ThemeToggleComponentController
  class AuctionCardComponentController
  class HeaderComponentController
  class NavbarComponentController
}

package "service" {
  class AuctionQueryService {
    - mapper : ProductCardMapper
    + getFeaturedAuctions() : List<ProductCardUiModel>
  }

  class HotReloadService {
    - sceneService : SceneService
    - themeService : ThemeService
    - cssDependencyIndex : CssDependencyIndex
    + start()
    + stop()
  }

  class ThemeService {
    - resourceLoader : ResourceLoader
    - currentTheme : Theme
    + currentTheme() : Theme
    + apply(scene : Scene, theme : Theme)
    + toggle(scene : Scene)
    + reloadIfThemeChanged(scene : Scene, changedCssPath : String)
  }

  enum Theme {
    LIGHT
    DARK
    + stylesheet() : String
  }

  class UserSessionService {
    - authenticated : boolean
    - username : String
    + isAuthenticated() : boolean
    + getUsername() : String
    + login(username : String)
    + logout()
  }

  class ResourceLoader
  class CssDependencyIndex
}

package "mapper" {
  class ProductCardMapper {
    + placeholder(index : int) : ProductCardUiModel
  }
}

package "dto" {
  class ProductCardUiModel <<record>> {
    + title : String
    + seller : String
    + currentBid : String
    + timeLeft : String
  }
}

package "exception" {
  class SceneLoadException
}

ClientApp --> SceneService
ClientApp --> NavigationService
ClientApp --> HotReloadService
ClientApp --> AppConfig
ClientApp --> SceneRegistry

NavigationService --> SceneService
SceneService --> SceneRegistry
SceneService --> ResourceLoader
SceneService ..> SceneLoadException

GeneralPageController --> GeneralPageViewModel
GeneralPageViewModel --> AuctionQueryService
AuctionQueryService --> ProductCardMapper
AuctionQueryService --> ProductCardUiModel
ProductCardMapper --> ProductCardUiModel

HotReloadService --> SceneService
HotReloadService --> ThemeService
HotReloadService --> CssDependencyIndex
ThemeService --> Theme
ThemeService --> ResourceLoader

note bottom of AuctionQueryService
  Current implementation returns
  placeholder UI data instead of
  calling the backend.
end note

ClientApp -[hidden]-> SceneService
SceneService -[hidden]-> GeneralPageController
GeneralPageController -[hidden]-> GeneralPageViewModel
GeneralPageViewModel -[hidden]-> AuctionQueryService
AuctionQueryService -[hidden]-> ProductCardMapper
ProductCardMapper -[hidden]-> ProductCardUiModel
GeneralPageController -[hidden]-> LoginPageController
LoginPageController -[hidden]-> ProductDetailPageController
ProductDetailPageController -[hidden]-> ProfilePageController
ProfilePageController -[hidden]-> RegisterPageController
GeneralPageViewModel -[hidden]-> LoginPageViewModel
LoginPageViewModel -[hidden]-> ProductDetailPageViewModel
ProductDetailPageViewModel -[hidden]-> ProfilePageViewModel
ProfilePageViewModel -[hidden]-> RegisterPageViewModel

@enduml
