<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.auction.client.page.general.GeneralPageController"
            styleClass="general-page-root">
    <top>
        <fx:include source="../components/shell/header.fxml" />
    </top>
    <left>
        <fx:include source="../components/shell/navbar.fxml" />
    </left>
    <center>
        <VBox spacing="12.0" styleClass="general-page-center" BorderPane.alignment="CENTER" fx:id="cardsContainer">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20" />
            </padding>
            <children>
                <fx:include source="../components/control/search-bar.fxml" />
                <fx:include source="../components/control/theme-toggle.fxml" />
            </children>
        </VBox>
    </center>
</BorderPane>