<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.auction.client.page.profile.PersonalProfileController"
            styleClass="profile-page-root">

    <!-- ======================== TOP: Header + Navbar ======================== -->
    <top>
        <VBox>
            <fx:include source="../components/shell/header.fxml" />
            <fx:include source="../components/shell/navbar.fxml" />
        </VBox>
    </top>

    <!-- ======================== CENTER: 2-Panel Layout ======================== -->
    <center>
        <StackPane fx:id="modalHost">
            <HBox styleClass="profile-layout">

            <!-- ============ LEFT PANEL: Sidebar ============ -->
            <VBox styleClass="profile-sidebar">

                <!-- Shared user-card: avatar + name + email -->
                <fx:include fx:id="profileSidebar"
                            source="../components/profile/profile-sidebar.fxml" />

                <!-- Toggle group for main nav -->
                <fx:define>
                    <ToggleGroup fx:id="navGroup" />
                </fx:define>

                <!-- Nav Menu -->
                <VBox styleClass="profile-nav-menu" VBox.vgrow="ALWAYS">
                    <Label text="NAVIGATE" styleClass="profile-nav-section-label" />

                    <ToggleButton fx:id="navDashboard"
                                  text="📊  Dashboard"
                                  styleClass="profile-nav-btn"
                                  toggleGroup="$navGroup"
                                  onAction="#handleNavDashboard"
                                  maxWidth="Infinity" />

                    <ToggleButton fx:id="navFinance"
                                  text="💰  Finance"
                                  styleClass="profile-nav-btn"
                                  toggleGroup="$navGroup"
                                  onAction="#handleNavFinance"
                                  maxWidth="Infinity" />

                    <ToggleButton fx:id="navMyBids"
                                  text="🔨  My Bids"
                                  styleClass="profile-nav-btn"
                                  toggleGroup="$navGroup"
                                  onAction="#handleNavMyBids"
                                  maxWidth="Infinity" />

                    <ToggleButton fx:id="navMyListings"
                                  text="📦  My Listings"
                                  styleClass="profile-nav-btn"
                                  toggleGroup="$navGroup"
                                  onAction="#handleNavMyListings"
                                  maxWidth="Infinity" />
                </VBox>

            </VBox>
            <!-- ============ END SIDEBAR ============ -->

            <!-- ============ RIGHT PANEL: Main Content ============ -->
            <ScrollPane styleClass="profile-cards-scroll"
                        fitToWidth="true"
                        HBox.hgrow="ALWAYS">
                <StackPane fx:id="contentArea" styleClass="profile-content-area">

                    <!-- == DASHBOARD SECTION == -->
                    <VBox fx:id="dashboardSection" spacing="8" visible="true" managed="true">

                        <Label text="Dashboard" styleClass="profile-section-title" />
                        <Label text="Your account overview" styleClass="profile-section-subtitle" />
                        <Region styleClass="profile-divider" maxWidth="Infinity" />

                        <!-- 2×2 stat cards -->
                        <HBox spacing="16">
                            <VBox styleClass="profile-stat-card" HBox.hgrow="ALWAYS">
                                <Label text="💰" styleClass="profile-stat-icon" />
                                <Label text="Total Balance" styleClass="profile-stat-label" />
                                <Label fx:id="dashTotalBalanceLabel" text="\$—"
                                       styleClass="profile-stat-value-small" />
                            </VBox>
                            <VBox styleClass="profile-stat-card" HBox.hgrow="ALWAYS">
                                <Label text="💵" styleClass="profile-stat-icon" />
                                <Label text="Available Balance" styleClass="profile-stat-label" />
                                <Label fx:id="dashAvailableBalanceLabel" text="\$—"
                                       styleClass="profile-stat-value-small" />
                            </VBox>
                        </HBox>

                        <HBox spacing="16">
                            <VBox styleClass="profile-stat-card" HBox.hgrow="ALWAYS">
                                <Label text="🔨" styleClass="profile-stat-icon" />
                                <Label text="Active Bids" styleClass="profile-stat-label" />
                                <Label fx:id="dashActiveBidsLabel" text="0"
                                       styleClass="profile-stat-value" />
                            </VBox>
                            <VBox styleClass="profile-stat-card" HBox.hgrow="ALWAYS">
                                <Label text="📦" styleClass="profile-stat-icon" />
                                <Label text="Active Listings" styleClass="profile-stat-label" />
                                <Label fx:id="dashActiveListingsLabel" text="0"
                                       styleClass="profile-stat-value" />
                            </VBox>
                        </HBox>

                    </VBox>
                    <!-- == END DASHBOARD == -->

                    <!-- == FINANCE SECTION == -->
                    <VBox fx:id="financeSection" spacing="8" visible="false" managed="false">

                        <Label text="Finance" styleClass="profile-section-title" />
                        <Label text="Manage your wallet" styleClass="profile-section-subtitle" />
                        <Region styleClass="profile-divider" maxWidth="Infinity" />

                        <VBox styleClass="profile-finance-card" spacing="4">
                            <HBox styleClass="profile-finance-row" alignment="CENTER_LEFT">
                                <Label text="Total Balance" styleClass="profile-finance-label"
                                       HBox.hgrow="ALWAYS" maxWidth="Infinity" />
                                <Label fx:id="finTotalBalanceLabel" text="\$0.00"
                                       styleClass="profile-finance-value" />
                            </HBox>
                            <HBox styleClass="profile-finance-row" alignment="CENTER_LEFT">
                                <Label text="Locked (Active Bids)" styleClass="profile-finance-label"
                                       HBox.hgrow="ALWAYS" maxWidth="Infinity" />
                                <Label fx:id="finLockedBalanceLabel" text="\$0.00"
                                       styleClass="profile-finance-value, profile-finance-value-locked" />
                            </HBox>
                            <Region styleClass="profile-finance-separator" maxWidth="Infinity" />
                            <HBox styleClass="profile-finance-row" alignment="CENTER_LEFT">
                                <Label text="Available Balance" styleClass="profile-finance-label"
                                       HBox.hgrow="ALWAYS" maxWidth="Infinity" />
                                <Label fx:id="finAvailableBalanceLabel" text="\$—"
                                       styleClass="profile-finance-value-available" />
                            </HBox>
                        </VBox>

                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <padding><Insets top="8" /></padding>
                            <Button text="Deposit"
                                    styleClass="profile-btn-action"
                                    onAction="#handleDeposit" />
                            <Button text="Withdraw"
                                    styleClass="profile-btn-action-outline"
                                    onAction="#handleWithdraw" />
                        </HBox>

                        <VBox spacing="8" fx:id="transactionHistorySection">
                            <padding><Insets top="20" /></padding>
                            <Label text="Transaction History" styleClass="profile-section-title"
                                   style="-fx-font-size: 18px;" />
                            <VBox fx:id="transactionListContainer" spacing="4" />
                            <Label fx:id="txEmptyLabel"
                                   text="No transactions yet."
                                   styleClass="profile-empty-state"
                                   maxWidth="Infinity"
                                   visible="true" managed="true" />
                        </VBox>

                    </VBox>
                    <!-- == END FINANCE == -->

                    <!-- == MY BIDS SECTION == -->
                    <VBox fx:id="myBidsSection" spacing="8" visible="false" managed="false">

                        <Label text="My Bids" styleClass="profile-section-title" />
                        <Label text="Auctions you are participating in" styleClass="profile-section-subtitle" />
                        <Region styleClass="profile-divider" maxWidth="Infinity" />

                        <fx:define>
                            <ToggleGroup fx:id="bidsTabGroup" />
                        </fx:define>
                        <HBox styleClass="profile-tab-bar" spacing="4">
                            <ToggleButton fx:id="bidsTabActive"
                                          text="Active Bids"
                                          styleClass="profile-tab-btn"
                                          toggleGroup="$bidsTabGroup"
                                          selected="true"
                                          onAction="#handleBidsTabActive" />
                            <ToggleButton fx:id="bidsTabWon"
                                          text="Won Auctions"
                                          styleClass="profile-tab-btn"
                                          toggleGroup="$bidsTabGroup"
                                          onAction="#handleBidsTabWon" />
                        </HBox>

                        <FlowPane fx:id="bidsCardsContainer"
                                  styleClass="profile-cards-flow"
                                  hgap="16" vgap="16" />

                        <Label fx:id="bidsEmptyLabel"
                               text="No bids yet. Start bidding on auctions!"
                               styleClass="profile-empty-state"
                               maxWidth="Infinity"
                               visible="true" managed="true" />

                    </VBox>
                    <!-- == END MY BIDS == -->

                    <!-- == MY LISTINGS SECTION == -->
                    <VBox fx:id="myListingsSection" spacing="8" visible="false" managed="false">

                        <Label text="My Listings" styleClass="profile-section-title" />
                        <Label fx:id="listingsStatsLabel"
                               text="Loading…"
                               styleClass="profile-section-subtitle" />
                        <Region styleClass="profile-divider" maxWidth="Infinity" />

                        <fx:define>
                            <ToggleGroup fx:id="listingsTabGroup" />
                        </fx:define>
                        <HBox styleClass="profile-tab-bar" spacing="4">
                            <ToggleButton fx:id="listingsTabLive"
                                          text="Live"
                                          styleClass="profile-tab-btn"
                                          toggleGroup="$listingsTabGroup"
                                          selected="true"
                                          onAction="#handleListingsTabLive" />
                            <ToggleButton fx:id="listingsTabPending"
                                          text="Pending"
                                          styleClass="profile-tab-btn"
                                          toggleGroup="$listingsTabGroup"
                                          onAction="#handleListingsTabPending" />
                            <ToggleButton fx:id="listingsTabSold"
                                          text="Sold"
                                          styleClass="profile-tab-btn"
                                          toggleGroup="$listingsTabGroup"
                                          onAction="#handleListingsTabSold" />
                            <ToggleButton fx:id="listingsTabUnsold"
                                          text="Unsold / Cancelled"
                                          styleClass="profile-tab-btn"
                                          toggleGroup="$listingsTabGroup"
                                          onAction="#handleListingsTabUnsold" />
                            <Region HBox.hgrow="ALWAYS" />
                            <Button text="+ Create Listing"
                                    styleClass="profile-create-btn"
                                    onAction="#handleCreateListing" />
                        </HBox>

                        <FlowPane fx:id="listingsCardsContainer"
                                  styleClass="profile-cards-flow"
                                  hgap="16" vgap="16" />

                        <Label fx:id="listingsEmptyLabel"
                               text="No listings in this category."
                               styleClass="profile-empty-state"
                               maxWidth="Infinity"
                               visible="true" managed="true" />

                    </VBox>
                    <!-- == END MY LISTINGS == -->

                </StackPane>
            </ScrollPane>
            <!-- ============ END MAIN CONTENT ============ -->

        </HBox>
        </StackPane>
    </center>

    <!-- ======================== BOTTOM: Footer ======================== -->
    <bottom>
        <fx:include source="../components/shell/footer.fxml" />
    </bottom>

</BorderPane>
