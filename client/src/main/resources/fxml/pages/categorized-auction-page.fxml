<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.auction.client.page.auction.CategorizedAuctionPageController"
      styleClass="general-page-root">
    <children>
        <VBox>
            <children>
                <fx:include source="../components/shell/header.fxml" />
                <fx:include source="../components/shell/navbar.fxml" />
            </children>
        </VBox>

        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                    styleClass="gp-scroll">
            <content>
                <VBox styleClass="gp-content-root">
                    <children>

                        <!-- Premium Category Type Selector -->
                        <HBox alignment="CENTER" spacing="32.0"
                              styleClass="gp-category-tabs-wrap">
                            <padding>
                                <Insets top="32.0" right="0.0" bottom="32.0" left="0.0" />
                            </padding>
                            <children>
                                <Button fx:id="btnLuxury"
                                        text="Luxury Collectibles"
                                        onAction="#handleSelectLuxury"
                                        styleClass="gp-category-tab-btn"
                                        focusTraversable="false" />
                                <Button fx:id="btnArtistic"
                                        text="Artistic Creations"
                                        onAction="#handleSelectArtistic"
                                        styleClass="gp-category-tab-btn"
                                        focusTraversable="false" />
                                <Button fx:id="btnPrecision"
                                        text="Precision Mechanicals"
                                        onAction="#handleSelectPrecision"
                                        styleClass="gp-category-tab-btn"
                                        focusTraversable="false" />
                            </children>
                        </HBox>

                        <!-- Subcategory rows populated dynamically by Controller -->
                        <VBox fx:id="subcategoriesContainer" spacing="0.0" styleClass="page-content-inset">
                        </VBox>

                        <fx:include source="../components/shell/footer.fxml" />

                    </children>
                </VBox>
            </content>
            <VBox.vgrow>
                <Priority fx:constant="ALWAYS" />
            </VBox.vgrow>
        </ScrollPane>

    </children>
</VBox>
