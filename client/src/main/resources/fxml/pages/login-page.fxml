<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.auction.client.page.login.LoginPageController"
      alignment="CENTER" spacing="16" styleClass="login-page-root">
    <padding><Insets top="64" right="64" bottom="64" left="64"/></padding>

    <Label text="Đăng nhập" styleClass="page-title"/>

    <TextField fx:id="txtUsername" promptText="Tên đăng nhập" styleClass="input-field"/>
    <PasswordField fx:id="txtPassword" promptText="Mật khẩu" styleClass="input-field"/>

    <Label fx:id="lblError" styleClass="error-label" visible="false" managed="false"
           wrapText="true"/>

    <Button text="Đăng nhập" onAction="#handleLogin" styleClass="btn-primary" maxWidth="Infinity"/>
    <Button text="Chưa có tài khoản? Đăng ký" onAction="#handleGoToRegister"
            styleClass="btn-link"/>
</VBox>