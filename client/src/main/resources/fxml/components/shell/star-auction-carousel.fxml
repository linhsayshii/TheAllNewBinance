<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>

<!--
    star-auction-carousel.fxml
    Shell cho toàn bộ Star Auction Banner / Carousel.
    - Padding ngang 0 150px để căn với lưới nội dung bên dưới.
    - Nút điều hướng dùng Text thuần "<" và ">".
    - fx:id="carouselViewport" là vùng hiển thị card (clip overflow).
    - fx:id="carouselTrack"   là HBox chứa tất cả card, dịch chuyển bằng TranslateX.
    - fx:id="dotContainer"   chứa các dot indicator.
    Carousel logic được xử lý hoàn toàn trong StarAuctionCarouselController.
-->
<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.auction.client.component.shell.StarAuctionCarouselController"
      styleClass="sa-carousel-root">

    <!-- Outer row: prev-btn | viewport | next-btn — với padding 0 150px -->
    <HBox alignment="CENTER_LEFT" styleClass="sa-carousel-row" minHeight="320" prefHeight="320">
        <padding>
            <Insets top="0" right="150" bottom="0" left="150" />
        </padding>

        <!-- Prev button -->
        <Label text="&lt;" onMouseClicked="#handlePrev"
               styleClass="sa-carousel-nav-btn" focusTraversable="false" />

        <!-- Viewport (clips overflow) -->
        <Pane fx:id="carouselViewport" styleClass="sa-carousel-viewport"
              minHeight="320" prefHeight="320" maxHeight="320">
            <HBox.hgrow>
                <Priority fx:constant="ALWAYS" />
            </HBox.hgrow>

            <!-- Track: all cards placed side-by-side, slides via translateX -->
            <HBox fx:id="carouselTrack" styleClass="sa-carousel-track" />
        </Pane>

        <!-- Next button -->
        <Label text="&gt;" onMouseClicked="#handleNext"
               styleClass="sa-carousel-nav-btn" focusTraversable="false" />
    </HBox>

    <!-- Dot indicators -->
    <HBox fx:id="dotContainer" alignment="CENTER" spacing="8.0"
          styleClass="sa-carousel-dots">
        <padding>
            <Insets top="12" right="0" bottom="4" left="0" />
        </padding>
    </HBox>

</VBox>
