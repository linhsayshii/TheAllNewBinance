<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.HBox?>

<HBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.auction.client.component.shell.NavbarComponentController"
      alignment="CENTER_LEFT" spacing="72.0" styleClass="gp-nav-bar">
    <padding>
        <Insets top="14.0" right="52.0" bottom="14.0" left="52.0" />
    </padding>
    <children>
        <Button text="AUCTIONS" styleClass="gp-nav-item" onAction="#handleGoToAuctions" />
        <Button text="CATEGORIES" styleClass="gp-nav-item" onAction="#handleGoToCategories" />
    </children>
</HBox>