<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.auction.client.page.register.RegisterPageController"
            styleClass="register-card-root">
    <center>
        <VBox alignment="CENTER" spacing="16">
            <padding><Insets top="48" right="48" bottom="48" left="48"/></padding>

            <Label text="Đăng ký tài khoản" styleClass="page-title"/>

            <TextField fx:id="txtUsername" promptText="Tên đăng nhập" styleClass="input-field" onAction="#handleRegister"/>
            <TextField fx:id="txtEmail" promptText="Email" styleClass="input-field" onAction="#handleRegister"/>
            <PasswordField fx:id="txtPassword" promptText="Mật khẩu (≥ 8 ký tự)" styleClass="input-field" onAction="#handleRegister"/>

            <Label fx:id="lblError" styleClass="error-label" visible="false" managed="${lblError.visible}" wrapText="true"/>

            <Button text="Tạo tài khoản" onAction="#handleRegister" styleClass="btn-primary" maxWidth="Infinity"/>
            <Button text="Đã có tài khoản? Đăng nhập" onAction="#handleGoToLogin" styleClass="btn-link"/>
        </VBox>
    </center>
</BorderPane>
