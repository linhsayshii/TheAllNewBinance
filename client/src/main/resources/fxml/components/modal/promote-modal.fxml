<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<!--
    promote-modal.fxml
    Promote Listing Modal — user chọn gói thời gian, xem preview description,
    rồi bấm "Thanh toán" để gọi PROMOTE_AUCTION request.
    Modal được load bởi PersonalProfileController và đặt trong một StackPane overlay.
-->
<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.auction.client.component.modal.PromoteModalController"
           styleClass="pm-overlay"
           onMouseClicked="#handleOverlayClick">

    <!-- Modal box (click consumed so it doesn't close) -->
    <VBox styleClass="pm-box" maxWidth="520" onMouseClicked="#consumeClick">
        <padding><Insets top="32" right="36" bottom="32" left="36" /></padding>

        <!-- Header -->
        <HBox alignment="CENTER_LEFT">
            <Label text="★  Promote Listing" styleClass="pm-title" />
            <Region HBox.hgrow="ALWAYS" />
            <Label text="✕" styleClass="pm-close-btn" onMouseClicked="#handleClose" />
        </HBox>

        <!-- Listing name preview -->
        <Label fx:id="listingNameLabel" text="—" styleClass="pm-listing-name" wrapText="true">
            <VBox.margin><Insets top="16" bottom="20" /></VBox.margin>
        </Label>

        <!-- Package selection -->
        <Label text="Chọn gói thời gian" styleClass="pm-section-label" />
        <HBox spacing="12">
            <VBox.margin><Insets top="8" bottom="20" /></VBox.margin>
            <fx:define>
                <ToggleGroup fx:id="packageGroup" />
            </fx:define>
            <ToggleButton fx:id="pkg1DayBtn"
                          text="1 Ngày — $100"
                          toggleGroup="$packageGroup"
                          styleClass="pm-pkg-btn"
                          onAction="#handlePackageChange" />
            <ToggleButton fx:id="pkg3DayBtn"
                          text="3 Ngày — $250"
                          toggleGroup="$packageGroup"
                          styleClass="pm-pkg-btn"
                          onAction="#handlePackageChange" />
        </HBox>

        <!-- Estimated end time -->
        <HBox alignment="CENTER_LEFT" spacing="6">
            <Label text="Thời gian kết thúc dự kiến:" styleClass="pm-meta-label" />
            <Label fx:id="estimatedEndLabel" text="—" styleClass="pm-meta-value" />
        </HBox>

        <!-- Short description textarea -->
        <Label text="Mô tả ngắn (hiển thị trên trang chủ)" styleClass="pm-section-label">
            <VBox.margin><Insets top="20" bottom="6" /></VBox.margin>
        </Label>
        <TextArea fx:id="descriptionArea"
                  promptText="Mô tả ngắn để thu hút người đấu giá... (để trống sẽ dùng mô tả gốc)"
                  wrapText="true"
                  prefHeight="90"
                  styleClass="pm-desc-area" />
        <Label text="Tối đa 200 ký tự" styleClass="pm-hint">
            <VBox.margin><Insets top="4" bottom="24" /></VBox.margin>
        </Label>

        <!-- Cost summary -->
        <HBox alignment="CENTER_LEFT" spacing="8" styleClass="pm-cost-row">
            <Label text="Tổng thanh toán:" styleClass="pm-cost-label" />
            <Label fx:id="costLabel" text="\$0" styleClass="pm-cost-value" />
            <Region HBox.hgrow="ALWAYS" />
            <Label text="Số dư hiện tại:" styleClass="pm-cost-label" />
            <Label fx:id="balanceLabel" text="\$0.00" styleClass="pm-balance-value" />
        </HBox>

        <!-- Action buttons -->
        <HBox spacing="12" alignment="CENTER_RIGHT">
            <VBox.margin><Insets top="20" /></VBox.margin>
            <Button text="Huỷ" styleClass="pm-cancel-btn" onAction="#handleClose" />
            <Button fx:id="confirmBtn" text="Thanh toán" styleClass="pm-confirm-btn" onAction="#handleConfirm" />
        </HBox>

        <!-- Result message -->
        <Label fx:id="resultLabel" text="" styleClass="pm-result" wrapText="true" visible="false" managed="false">
            <VBox.margin><Insets top="12" /></VBox.margin>
        </Label>
    </VBox>

</StackPane>
