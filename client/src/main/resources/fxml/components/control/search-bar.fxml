<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>

<HBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.auction.client.component.control.SearchBarComponentController"
      spacing="8.0" styleClass="search-bar-root">
    <children>
        <TextField promptText="Search auction..." HBox.hgrow="ALWAYS" />
        <Button text="Search" />
    </children>
    <padding>
        <Insets top="8" right="0" bottom="8" left="0" />
    </padding>
</HBox>